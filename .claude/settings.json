{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(make setup)",
      "Bash(source ~/.zshrc)",
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git -C * status)",
      "Bash(git -C * status *)",
      "Bash(git log)",
      "Bash(git log *)",
      "Bash(git -C * log)",
      "Bash(git -C * log *)",
      "Bash(git diff)",
      "Bash(git diff *)",
      "Bash(git -C * diff)",
      "Bash(git -C * diff *)",
      "Bash(git show)",
      "Bash(git show *)",
      "Bash(git branch)",
      "Bash(git branch *)",
      "Bash(git -C * branch)",
      "Bash(git -C * branch *)",
      "Bash(git add *)",
      "Bash(git -C * add *)",
      "Bash(git fetch)",
      "Bash(git fetch *)",
      "Bash(git stash)",
      "Bash(git stash *)",
      "Bash(git checkout *)",
      "Bash(git switch *)",
      "Bash(git restore *)",
      "Bash(git rebase)",
      "Bash(git rebase *)",
      "Bash(git merge *)",
      "Bash(git tag)",
      "Bash(git tag *)",
      "Bash(git remote)",
      "Bash(git remote *)",
      "Bash(git config *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(diff *)",
      "Bash(ls)",
      "Bash(ls **)",
      "Bash(ls -* **)",
      "Bash(which *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(echo *)",
      "Bash(printf *)",
      "Bash(stat *)",
      "Bash(file *)",
      "Bash(du *)",
      "Bash(df *)",
      "Bash(pwd)",
      "Bash(env)",
      "Bash(printenv *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(cut *)",
      "Bash(ps *)",
      "Bash(uname *)",
      "Bash(date *)",
      "Bash(type *)",
      "Bash(gh api *)",
      "Bash(gh pr *)",
      "Bash(* --version)",
      "Bash(* -v)",
      "Bash(* -V)",
      "Bash(* --help *)",
      "mcp__playwright",
      "Bash(npx @playwright/mcp@latest)",
      "Bash(playwright *)",
      "WebFetch",
      "mcp__pencil",
      "Read",
      "Glob",
      "Grep"
    ],
    "deny": [
      "Bash(find * -exec *)",
      "Bash(find * -delete *)",
      "Bash(rm -rf *)",
      "Bash(chmod 777 *)",
      "Bash(curl | sh *)",
      "Bash(sudo *)",
      "Bash(gh api -X DELETE *)",
      "Bash(gh api --method DELETE *)",
      "Bash(gh pr merge *)",
      "Bash(gh pr close *)"
    ],
    "ask": [
      "Edit(/**)",
      "Write(/**)",
      "Bash"
    ]
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/wezterm-notify.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/wezterm-notify.sh"
          }
        ]
      }
    ]
  },
  "defaultMode": "default",
  "language": "japanese",
  "enabledPlugins": {
    "document-skills@anthropic-agent-skills": true,
    "example-skills@anthropic-agent-skills": true,
    "playwright@claude-plugins-official": true
  },
  "note": "Claude Codeの権限管理。allow/deny/askルールは公式ドキュメントの構文に準拠。プロジェクトルート以外でも .claude/settings.json を置けば効きます。"
}
