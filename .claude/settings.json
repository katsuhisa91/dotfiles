{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(make setup)",
      "Bash(source ~/.zshrc)",
      "Bash(git *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(diff *)",
      "Bash(ls)",
      "Bash(ls *)",
      "Bash(which *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(gh api *)",
      "Bash(gh pr *)",
      "Bash(* --version)",
      "Bash(* -v)",
      "Bash(* -V)",
      "Bash(* --help *)",
      "mcp__playwright",
      "Bash(npx @playwright/mcp@latest)",
      "Bash(playwright *)",
      "mcp__pencil",
      "WebFetch(*)"
    ],
    "deny": [
      "Bash(find * -exec *)",
      "Bash(find * -delete *)",
      "Bash(rm -rf *)",
      "Bash(chmod 777 *)",
      "Bash(curl | sh *)",
      "Bash(sudo *)",
      "Bash(git push *)",
      "Bash(git -C * push *)",
      "Bash(gh api -X DELETE *)",
      "Bash(gh api --method DELETE *)",
      "Bash(gh pr merge *)",
      "Bash(gh pr close *)"
    ],
    "ask": [
      "Edit(/**)",
      "Write(/**)",
      "Bash(*)"
    ]
  },
  "defaultMode": "default",
  "language": "japanese",
  "enabledPlugins": {
    "document-skills@anthropic-agent-skills": true,
    "example-skills@anthropic-agent-skills": true,
    "playwright@claude-plugins-official": true
  },
  "note": "Claude Codeの権限管理。allow/deny/askルールは公式ドキュメントの構文に準拠。プロジェクトルート以外でも .claude/settings.json を置けば効きます。"
}