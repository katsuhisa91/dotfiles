{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(make setup)",
      "Bash(source ~/.zshrc)",
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git diff)",
      "Bash(git diff *)",
      "Bash(git log)",
      "Bash(git log *)",
      "Bash(git show)",
      "Bash(git show *)",
      "Bash(diff *)",
      "Bash(ls)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(gh pr list)",
      "Bash(gh pr list *)",
      "Bash(gh pr view)",
      "Bash(gh pr view *)",
      "Bash(gh pr diff)",
      "Bash(gh pr diff *)",
      "Bash(gh pr checks)",
      "Bash(gh pr checks *)",
      "Bash(gh pr status)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git * main)",
      "Bash(* --version)",
      "Bash(* -v)",
      "Bash(* -V)",
      "Bash(* --help *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(chmod 777 *)",
      "Bash(curl | sh *)",
      "Bash(sudo *)",
      "Bash(git push *)"
    ],
    "ask": [
      "Edit(/**)",
      "Write(/**)",
      "Bash(*)"
    ]
  },
  "defaultMode": "default",
  "language": "japanese",
  "note": "Claude Codeの権限管理。allow/deny/askルールは公式ドキュメントの構文に準拠。プロジェクトルート以外でも .claude/settings.json を置けば効きます。"
}
